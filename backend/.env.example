# Base de donnees PostgreSQL
DATABASE_URL=postgresql+psycopg://postgres:change_me@localhost:5432/tfe_gestion_acces

# Active les logs SQL en developpement
SQL_ECHO=false

# JWT
JWT_SECRET_KEY=change_me_with_a_long_random_secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
DEFAULT_ADMIN_EMAIL=admin@gestion-acces.dev
DEFAULT_ADMIN_PASSWORD=Admin123!
DEFAULT_ADMIN_PRENOM=Admin
DEFAULT_ADMIN_NOM=Local

# API FastAPI
API_HOST=127.0.0.1
API_PORT=8000
API_RELOAD=true

# Emails locaux avec Mailpit ou un serveur SMTP de test
SMTP_ENABLED=false
SMTP_HOST=127.0.0.1
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@gestion-acces.dev
SMTP_USE_TLS=false
